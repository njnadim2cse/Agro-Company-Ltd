<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_flock_body_weight_tree" model="ir.ui.view">
        <field name="name">flock.body.weight.list</field>
        <field name="model">flock.body.weight</field>
        <field name="arch" type="xml">
           <list string="Flock Body Weight" decoration-info="state == 'draft'" decoration-success="state == 'done'">
                <field name="date" width="120"/>
                <field name="name" width="120"/>
                <field name="created_by" widget="many2one_avatar_user" width="120"/>
                <field name="flock_id" width="100" string="Flock Name"/>
                <field name="state" widget="badge" decoration-success="state=='done'" decoration-warning="state=='draft'" width="120"/>
                <field name="act_weight" width="120"/>
                <field name="std_weight" width="120" invisible="state == 'draft'"/>
            </list>
        </field>
    </record>
    
    <record id="view_flock_body_weight_form" model="ir.ui.view">
        <field name="name">flock.body.weight.form</field>
        <field name="model">flock.body.weight</field>
        <field name="arch" type="xml">
            <form string="Flock Body Weight">
                 <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                    <button name="action_confirm" string="Confirm" class="oe_highlight" type="object" icon="fa-check" invisible="state != 'draft'"/>
                    <button name="action_draft" string="Return to Draft" type="object" icon="fa-undo" class="btn-secondary" invisible="state != 'done'"/>

                </header>
                <sheet>
                <div>
                      <h1>  <field name="name" readonly="1"/></h1>
                        <field name="date" readonly="1"/>
                    
                </div>
                <group>
          
                    <group string="Flock Details">
                            <h1><field name="flock_id" placeholder="Select Flock" options="{'no_create': True}"  required="1"/></h1>   
                            <field name="current_birds"/>
                            <field name="birds_type"/>
                            <field name="age_in_days"/>
                            <field name="age_in_weeks"/>
                    </group>

                    <group string="Body Weight">
                            <field name="act_weight" required="1"/>
                            <field name="std_weight" required="1"/>
                            <field name="min_weight" required="1"/>
                            <field name="max_weight" required="1"/>
                    </group>

                </group>

                 <notebook>
                    <page string="Body Weight Notes &amp; Observations">
                         <field name="note_html"/>
                    </page>
                 </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
       <record id="action_flock_body_weight" model="ir.actions.act_window">
            <field name="name">Flock Body Weight</field>
            <field name="res_model">flock.body.weight</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_flock_body_weight_tree"/>
        </record>
    <!-- <menuitem id="menu_flock_body_weight" name="Body Weight" parent="menu_layer_flock_root" action="action_flock_body_weight"  sequence="31"/> -->
    
</odoo>
