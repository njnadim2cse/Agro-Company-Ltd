<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_farm_water_intake_tree" model="ir.ui.view">
            <field name="name">farm.water.intake.list</field>
            <field name="model">farm.water.intake</field>
            <field name="arch" type="xml">

               <list string="Water Intake Records" default_order="date desc" decoration-info="state == 'draft'" decoration-success="state == 'done'">
                    <field name="date" width="100"/>
                    <field name="flock_id" width="100" invisible="state == 'draft'" string="Flock Name"/>
                    <field name="created_by" widget="many2one_avatar_user" width="120"/>
                    <field name="state" widget="badge" decoration-success="state=='done'" decoration-warning="state=='draft'" width="120"/>
                    <field name="current_birds" width="100" invisible="state == 'draft'"/>
                    <field name="water_lit" width="100"/>
                    <field name="cumulative_water" width="100" string="Cumulative Water"/>
                </list>

            </field>
        </record>

        <record id="view_farm_water_intake_form" model="ir.ui.view">
            <field name="name">farm.water.intake.form</field>
            <field name="model">farm.water.intake</field>
            <field name="arch" type="xml">
                <form string="Water Intake">
                       <header>
                            <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                            <button name="action_confirm" string="Confirm" class="oe_highlight" type="object" icon="fa-check" invisible="state != 'draft'"/>
                            <button name="action_draft" string="Return to Draft" type="object" icon="fa-undo" class="btn-secondary" invisible="state != 'done'"/>
                        </header>
                    <sheet>
                        <div>
                              <h1>  <field name="name" readonly="1"/></h1>
                        </div>
                        <field name="date" required="1" readonly="1"/>
                        <group>

                            <group string="Basic Information" readonly="state != 'draft' ">
                                <h1><field name="flock_id" required="1" readonly="state != 'draft' " placeholder="Select Flock" options="{'no_create': True}"/></h1>
                                <field name="current_age_days" readonly="state != 'draft' "/>
                                <field name="current_age_display" readonly="state != 'draft' "/>
                                <field name="current_birds" readonly="state != 'draft' "/>
                                <field name="bird_type" readonly="state != 'draft' "/>
                            </group>
                            <group string="Water Intake Details" readonly="state != 'draft' ">
                                <field name="providing_category" widget="selection" options="{'no_create': True}" readonly="state != 'draft' "/>
                                <field name="water_lit" readonly="state != 'draft' "/>
                                <field name="water_ml_per_bird" readonly="state != 'draft' "/>
                            </group>
                        </group>
                           <notebook>
                                <page string="Related  Note">
                                    <field name="note_html"/>
                                </page>
                            </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Action for Farm Water Intake -->
        <record id="action_farm_water_intake" model="ir.actions.act_window">
            <field name="name">Water Intake Records</field>
            <field name="res_model">farm.water.intake</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Menu Item -->
        <!-- <menuitem id="menu_farm_water_intake" name="Water Intake" parent="menu_layer_flock_root" action="action_farm_water_intake" sequence="121"/> -->
    </data>
</odoo>