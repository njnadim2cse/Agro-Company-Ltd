<odoo>

    <!-- Form View for farm.ventilation.level.line -->
    <record id="view_farm_ventilation_level_line_form" model="ir.ui.view">
        <field name="name">farm.ventilation.level.line.form</field>
        <field name="model">farm.ventilation.level.line</field>
        <field name="arch" type="xml">
            <form string="Farm Ventilation Level Line">
                <sheet>
                    <group>
                        
                        <group>
                           <field name="level_id" readonly="1"/>
                           <field name="target_temperature" readonly="1"/>
                            <field name="max_temperature" readonly="1"/>
                            <field name="min_temperature" readonly="1"/>
                        </group>
                        <group>
                            <field name="fan_ids" widget="many2many_tags" readonly="1"/>
                            <field name="fan_count" readonly="1"/>
                            <field name="LRF_value" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

</odoo>
