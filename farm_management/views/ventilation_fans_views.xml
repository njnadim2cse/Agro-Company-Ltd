<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_ventilation_fans_list" model="ir.ui.view">
        <field name="name">ventilation.fans.list</field>
        <field name="model">ventilation.fans</field>
        <field name="arch" type="xml">

            <list string="Ventilation Fans" decoration-info="state == 'draft'" decoration-success="state == 'done'" >
                <field name="reference" width="100"/>
                <field name="name" width="100"/>
                <field name="created_by" widget="many2one_avatar_user" width="120"/>
                <field name="state"  widget="badge" decoration-success="state=='done'" decoration-warning="state=='draft'" width="120"/>
            </list>

        </field>
    </record>
    <record id="view_ventilation_fans_form" model="ir.ui.view">
        <field name="name">ventilation.fans.form</field>
        <field name="model">ventilation.fans</field>
        <field name="arch" type="xml">
            <form string="Ventilation Fan">
            <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                    <button name="action_confirm" string="Confirm" class="oe_highlight" type="object" icon="fa-check" invisible="state != 'draft'"/>
                    <button name="action_draft" string="Reset to Draft" type="object" icon="fa-undo" class="btn-secondary" invisible="state != 'done'"/>
            </header>

                <sheet>
                    <div>
                      <h1> <field name="reference" readonly="1"/></h1>
                      <field name="date" readonly="1"/>
                    </div>

                    <group string="Ventilation Fan Details">
                        <field name="name" readonly="state != 'draft' "/>
                        <field name="description" placeholder="Enter description here..." widget="html_sanitized" readonly="state != 'draft' "/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_ventilation_fan" model="ir.actions.act_window">
        <field name="name">Ventilation Fans</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">ventilation.fans</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_ventilation_fans_list"/>
    </record>


</odoo>
