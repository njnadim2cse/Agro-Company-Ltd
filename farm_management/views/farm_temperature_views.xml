<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="action_farm_temperature" model="ir.actions.act_window">
        <field name="name">Temperature Records</field>
        <field name="res_model">farm.temperature</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_farm_temperature_tree" model="ir.ui.view">
        <field name="name">farm.temperature.list</field>
        <field name="model">farm.temperature</field>
        <field name="arch" type="xml">
            <list string="Temperature Records" default_order="date desc" decoration-info="state == 'draft'" decoration-success="state == 'done'">
                <field name="date" width="100"/>
                <field name="name" width="120"/>
                <field name="created_by" widget="many2one_avatar_user" width="120"/>
                 <field name="state" widget="badge" decoration-success="state=='done'" decoration-warning="state=='draft'" width="120"/>
                <field name="temp_max" width="100" invisible="state == 'draft'"/>
                <field name="temp_min" width="100" invisible="state == 'draft'"/>
            </list>

        </field>
    </record>

    <record id="view_farm_temperature_form" model="ir.ui.view">
        <field name="name">farm.temperature.form</field>
        <field name="model">farm.temperature</field>
        <field name="arch" type="xml">
            <form string="Temperature Record">
                 <header>
                        <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                        <button name="action_confirm" string="Confirm" class="oe_highlight" type="object" icon="fa-check" invisible="state != 'draft'"/>
                        <button name="action_draft" string="Return to Draft" type="object" icon="fa-undo" class="btn-secondary" invisible="state != 'done'"/>
                </header>
                <sheet>
                    <div>
                      <h1>  <field name="name" readonly="1"/></h1>
                      <field name="date" readonly="1"/>
                    </div>
                   <group>
                        <group>
                            <separator string="Flock Information" colspan="4"/>
                            <field name="flock_id" readonly="state != 'draft' "/>
                            <field name="current_birds" readonly="state != 'draft' "/>
                            <field name="birds_type" readonly="state != 'draft' "/>
                            <field name="age_in_days" readonly="state != 'draft' "/>
                            <field name="current_birds" readonly="state != 'draft' "/>
                        </group>
                        <group>
                            <separator string="Inside Temperature" colspan="4"/>
                            <field name="temp_max" readonly="state != 'draft' "/>
                            <field name="temp_min" readonly="state != 'draft' "/>
                        </group>
                        
                    </group>
                    <notebook>
                        <page string="Medicine">
                                <field name="daily_temperature_ids" readonly="state != 'draft' ">
                                     <list editable="bottom" decoration-info="state == 'draft'" decoration-success="state == 'done'">
                                        <field name="product_id" width="150" />
                                        <field name="total_quantity" width="120" />
                                        <field name="consume_quantity" width="120"/>
                                        <field name="cost" width="120" />
                                        <field name="state" width="100" widget="badge" decoration-success="state == 'done'" decoration-warning="state == 'draft'"/>
                                    </list>
                                </field>
                        </page>
                    </notebook>
                 </sheet>
               <chatter/>
            </form>
        </field>
    </record>

    <!-- <menuitem id="menu_farm_temperature_root" name="Suggest Medicine Manually" parent="menu_layer_flock_root" sequence="198" action="action_farm_temperature"/> -->
   
</odoo>
