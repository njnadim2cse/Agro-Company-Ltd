<odoo>
    <menuitem id="menu_hatchery_management" name="Hatchery Management" sequence="10"/>
    

    <!-- Action -->
    <record id="action_prestorage_batch" model="ir.actions.act_window">
        <field name="name">Pre-Storage Batches</field>
        <field name="res_model">hatchery.prestorage.batch</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_prestorage_root" name="Pre-Storage" parent="menu_hatchery_management" sequence="10" action="action_prestorage_batch"/>

    <!-- List View -->
    <record id="view_prestorage_batch_list" model="ir.ui.view">
        <field name="name">prestorage.batch.list</field>
        <field name="model">hatchery.prestorage.batch</field>
        <field name="arch" type="xml">
            <list>
             
                <field name="name" readonly="1"/>
                <field name="date_in"/>
                <field name="qty_received"/>
                <field name="available_qty"/>
                <field name="pre_storage_waste"/>
                <field name="success_rate"/>
                <field name="company_id"/>
                <field name="transfer_status"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_prestorage_batch_form" model="ir.ui.view">
        <field name="name">prestorage.batch.form</field>
        <field name="model">hatchery.prestorage.batch</field>
        <field name="arch" type="xml">
            <form string="Pre-Storage Batch">
<header>
   
</header>
                <sheet>
                    <h1>
                       <field name="name" readonly="1"/>
                    </h1>
                    <group>
                        <group>
                            <field name="date_in"/>
                            <field name="qty_received"/>
                            <field name="available_qty" readonly="1"/>
                        </group>
                        <group>
                            <field name="pre_storage_waste"/>
                            <field name="success_rate" readonly="1"/>
                        
                        </group>
                    </group>



                    <group>
                        <field name="stock_scrap_id" readonly="1"/>
                    </group>
                
                <notebook>
                    <page string="Break History">
                       <field name="break_history_ids">
                           <list editable="bottom">
                             <field name="date" readonly="1"/>
                             <field name="break_qty"/>
                             <field name="break_reason"/>
                             <field name="note"/>
                             <field name="user_id" readonly="1"/>
                             <field name="processed" readonly="1"/>
                             <field name="stock_scrap_id"/>
                             <button name="action_break_eggs"
                                   type="object"
                                   string="Egg Breakage"
                                   class="btn btn-light-red btn-sm"
                                   icon="fa-exclamation-triangle" invisible ="processed != False"/>
                               
                            </list>
                       </field>
                   </page>
                   <page string="Transfers">
                        <field name="egg_transfer_ids">
                            <list editable="bottom" class="oe_list_small">
                                 <field name="available_qty" string="Available Qty" readonly="1" options="{'width': 150}"/>
                                 <field name="transfer_qty" string="Transfer Quantity" options="{'width': 150}"/>
                                 <field name="state" string="Status" readonly="1" options="{'width': 1}"/>
                               
                                 <button name="action_transfer"
                                            type="object"
                                            string="Transfer To Egg Batch"
                                            class="btn btn-light-success btn-sm"
                                            icon="fa-arrow-right"
                                            title="Transfer"
                                            attrs="{'invisible': [('can_transfer', '=', False)]}"/>

                                
                                
                            </list>
                        </field>
                    </page>
                </notebook>
                 </sheet>
                <chatter/>
            </form>
        </field>
    </record>
</odoo>


