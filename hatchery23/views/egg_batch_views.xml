<odoo>
    <!-- Menu -->
    

    <!-- Action -->
    <record id="action_egg_batch" model="ir.actions.act_window">
        <field name="name">Egg Batches</field>
        <field name="res_model">hatchery.egg.batch</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu for Egg Batch -->
    <menuitem id="menu_egg_batch_root" name="Egg Batch"  parent="menu_hatchery_management" sequence="20"  action="action_egg_batch"/>


    <!-- List View -->
    <record id="view_egg_batch_list" model="ir.ui.view">
        <field name="name">egg.batch.list</field>
        <field name="model">hatchery.egg.batch</field>
        <field name="arch" type="xml">
            <list>
                <field name="batch_no" readonly="1"/>
                <field name="prestorage_id"/>
                <field name="user_id"/>
                <field name="date_received"/>
                <field name="qty_received"/>
                <field name="qty_available"/>
                <field name="company_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_egg_batch_form" model="ir.ui.view">
        <field name="name">egg.batch.form</field>
        <field name="model">hatchery.egg.batch</field>
        <field name="arch" type="xml">
            <form string="Egg Batch">
                <header>
                    <button name="action_send_to_setter" type="object" string="Send to Setter" class="btn-primary" icon="fa-arrow-right"/>
                    
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_setter"/>
                </header>

                <sheet>
                     <h1>
                       <field name="batch_no" readonly="1"/>
                     </h1>
                    <group>
                        <group>
                           
                            <field name="date_received"/>
                            <field name="qty_received"/>
                            <field name="qty_available"/>
                        </group>
                        <group>
                            
                        
                            <field name="prestorage_id"/>
                        </group>
                    </group>                             
                    <notebook>
                           
                    

                        <page string="Break History">
                          <field name="break_line_ids">
                             <list editable="bottom">
                                <field name="date" readonly="1"/>
                                <field name="break_qty"/>
                                <field name="break_reason"/>
                                <field name="user_id" readonly="1"/>
                                <field name="stock_scrap_id"/>
                                <field name="processed" readonly="1"/>
                                <button name="action_break_eggs"
                                   type="object"
                                   string="Egg Breakage"
                                   class="btn btn-light-red btn-sm"
                                   icon="fa-exclamation-triangle" invisible ="processed != False"/>
                               
                            </list>
                       </field>
                   </page>

                       
                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>
</odoo>



