<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Formula List View -->
    <record id="view_feed_formula_list" model="ir.ui.view">
        <field name="name">feed.formula.list</field>
        <field name="model">feed.formula</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="poultry_type"/>
                <field name="age_from"/>
                <field name="age_to"/>
                <field name="date_type"/>
                <field name="batch_name"/>
                <field name="nutrition_status" widget="selection_badge"/>
                <field name="total_cost_per_100kg"/>
            </list>
        </field>
    </record>

     <!-- Formula Form View -->
    <record id="view_feed_formula_form" model="ir.ui.view">
        <field name="name">feed.formula.form</field>
        <field name="model">feed.formula</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="poultry_type"/>
                            <field name="batch_name"/>
                        </group>
                        <group>
                            <field name="age_from"/>
                            <field name="age_to"/>
                            <field name="date_type"/>
                            <field name="actual_batch_size" readonly="1"/>
                            <field name="nutrition_status" widget="selection_badge"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Ingredient Observation">
                            <field name="ingredient_observation_ids" readonly="1">
                                <list>
                                    <field name="ingredient_id"/>
                                    <field name="quantity_per_100kg"/>
                                    <field name="unit_cost"/>
                                    <field name="cost_per_100kg"/>
                                </list>
                            </field>
                            <div class="alert alert-info" role="alert">
                                Total Cost per 100kg: <strong><field name="total_cost_per_100kg"/></strong>
                            </div>
                        </page>
                        <page string="Nutrients Observation">
                            <field name="nutrient_observation_ids" readonly="1">
                                <list default_order="nutrition_id, ingredient_id">
                                    <field name="nutrition_id"/>
                                    <field name="percentage_per_100kg"/>
                                    <field name="quantity_per_100kg"/>
                                    <field name="total_percentage_per_100kg"/>
                                    <field name="ingredient_id"/>
                                </list>
                            </field>
                        </page>
                        <page string="Total Nutrients Summary">
                            <field name="total_nutrient_summary_ids" readonly="1">
                                <list>
                                    <field name="nutrition_id"/>
                                    <field name="min_standard"/>
                                    <field name="max_standard"/>
                                    <field name="required_standard"/>
                                    <field name="actual_used_percent"/>
                                    <field name="status" widget="selection_badge" 
                                        options="{'classes': {'no_standard': 'bg-light', 'within_range': 'bg-success', 'below_min': 'bg-warning', 'above_max': 'bg-danger'}}"/>
                                </list>
                            </field>
                            <div class="alert alert-info" role="alert">
                                <strong>Status Legend:</strong>
                                <span class="badge bg-light">No Standard</span> - No min/max standard defined,
                                <span class="badge bg-success">Within Range</span> - Between min and max standards (Satisfied),
                                <span class="badge bg-warning">Below Minimum</span> - Below min standard (Unsatisfied),
                                <span class="badge bg-danger">Above Maximum</span> - Exceeds max standard (Unsatisfied)
                            </div>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Formula Action -->
    <record id="action_feed_formula" model="ir.actions.act_window">
        <field name="name">Formulas</field>
        <field name="res_model">feed.formula</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>